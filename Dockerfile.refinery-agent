# Dockerfile for Refinery Agent - Email Processing Worker (Spark-2)
FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy requirements
COPY requirements.txt* ./

# Install Python dependencies
RUN pip install --no-cache-dir \
    psycopg2-binary \
    python-dotenv \
    requests \
    sqlalchemy

# Copy mining rig script and dependencies
COPY src/mining_rig_with_router.py /app/mining_rig_with_router.py
COPY src/data_router.py /app/data_router.py
COPY src/enrichment_service.py /app/enrichment_service.py

# Make scripts executable
RUN chmod +x /app/mining_rig_with_router.py

# Environment variables (can be overridden in docker-compose)
ENV NODE_NAME=spark-2-refinery
ENV BATCH_SIZE=20
ENV SLEEP_INTERVAL=5

# Run the Refinery Agent
CMD ["python", "/app/mining_rig_with_router.py"]
