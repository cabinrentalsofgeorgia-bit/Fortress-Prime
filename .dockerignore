# =============================================================================
# FORTRESS PRIME — Docker Build Exclusions
# =============================================================================

# Version control
.git
.gitignore

# Python caches
__pycache__
*.pyc
*.pyo
.mypy_cache
.pytest_cache

# IDE / editor
.cursor
.vscode
*.swp
*.swo
*~

# Virtual environments
venv
.venv
env

# Large data files (mounted at runtime, not baked in)
*.pdf
*.csv
*.sqlite3
*.db

# NAS data (mounted at runtime)
mnt/

# Logs (mounted at runtime)
logs/
*.log

# Docker files (don't nest)
Dockerfile*
docker-compose*.yml

# Misc
cleanup_log.txt
full_folder_manifest.txt
nas_file_structure.txt
site_content_map.csv
cluster_specs.txt
*.json.bak
.env.bak
.env.pre_renew_*

# Node (if any)
node_modules
