        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "fortress-pg"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  series.day::timestamptz AS time,\n  COALESCE(created.cnt, 0) AS \"Created\",\n  COALESCE(completed.cnt, 0) AS \"Completed\"\nFROM generate_series(NOW() - INTERVAL '30 days', NOW(), '1 day') AS series(day)\nLEFT JOIN (\n  SELECT date_trunc('day', created_at)::date AS d, COUNT(*) AS cnt\n  FROM ops_tasks\n  WHERE created_at >= NOW() - INTERVAL '30 days'\n  GROUP BY 1\n) created ON created.d = series.day::date\nLEFT JOIN (\n  SELECT date_trunc('day', completed_at)::date AS d, COUNT(*) AS cnt\n  FROM ops_tasks\n  WHERE status IN ('DONE', 'COMPLETE') AND completed_at IS NOT NULL AND completed_at >= NOW() - INTERVAL '30 days'\n  GROUP BY 1\n) completed ON completed.d = series.day::date\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Task Completion Trend",
      "type": "timeseries"
    },
