          "rawSql": "SELECT\n  (date_trunc('day', checkout_time))::timestamptz AS time,\n  status AS metric,\n  COUNT(*) AS value\nFROM ops_turnovers\nWHERE checkout_time >= NOW() - INTERVAL '30 days'\nGROUP BY 1, 2\nORDER BY 1",
