          "format": "table",
          "rawSql": "SELECT\n  p.internal_name AS \"Property\",\n  t.checkout_time AS \"Checkout\",\n  t.checkin_time AS \"Check-in\",\n  t.status AS \"Status\",\n  (SELECT COUNT(*) FROM ops_tasks WHERE turnover_id = t.id) AS \"Task Count\"\nFROM ops_turnovers t\nJOIN ops_properties p ON p.property_id = t.property_id\nWHERE t.status NOT IN ('READY', 'COMPLETE')\nORDER BY t.checkout_time ASC",
          "refId": "A"
        }
