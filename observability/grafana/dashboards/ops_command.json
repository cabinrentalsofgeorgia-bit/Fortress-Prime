          "format": "table",
          "rawSql": "SELECT\n  COALESCE(c.name, 'Unassigned') AS \"Crew Member\",\n  COUNT(*) AS \"Open Tasks\"\nFROM ops_tasks t\nLEFT JOIN ops_crew c ON c.id = t.assigned_to\nWHERE t.status IN ('OPEN', 'ASSIGNED', 'IN_PROGRESS')\nGROUP BY c.name, c.id\nORDER BY COUNT(*) DESC",
