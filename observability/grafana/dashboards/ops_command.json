          "format": "table",
          "rawSql": "SELECT\n  CASE COALESCE(priority, 'NORMAL')\n    WHEN 'EMERGENCY' THEN '1-Critical'\n    WHEN 'URGENT' THEN '2-High'\n    WHEN 'NORMAL' THEN '3-Normal'\n    WHEN 'LOW' THEN '4-Low'\n    ELSE '5-Low'\n  END AS \"Priority\",\n  COUNT(*) AS \"Count\"\nFROM ops_tasks\nWHERE status IN ('OPEN', 'ASSIGNED', 'IN_PROGRESS')\nGROUP BY priority\nORDER BY CASE priority WHEN 'EMERGENCY' THEN 1 WHEN 'URGENT' THEN 2 WHEN 'NORMAL' THEN 3 WHEN 'LOW' THEN 4 ELSE 5 END",
          "refId": "A"
        }
      ],
      "title": "Tasks by Priority",
