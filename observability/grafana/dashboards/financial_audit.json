          "format": "time_series",
          "rawSql": "SELECT date_trunc('day', je.entry_date)::timestamptz AS time, COALESCE(SUM(CASE WHEN a.account_type = 'Revenue' THEN jli.credit ELSE 0 END), 0) AS \"Revenue\", COALESCE(SUM(CASE WHEN a.account_type = 'Expense' THEN jli.debit ELSE 0 END), 0) AS \"Expenses\" FROM journal_line_items jli JOIN journal_entries je ON jli.journal_entry_id = je.id JOIN accounts a ON jli.account_id = a.id WHERE $__timeFilter(je.entry_date::timestamptz) AND je.is_void = false GROUP BY date_trunc('day', je.entry_date) ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Revenue vs Expenses",
      "type": "timeseries"
