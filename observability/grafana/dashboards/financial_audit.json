          "format": "table",
          "rawSql": "SELECT a.account_type AS \"Type\", CASE WHEN a.account_type IN ('Asset', 'Expense') THEN COALESCE(SUM(jli.debit - jli.credit), 0) ELSE COALESCE(SUM(jli.credit - jli.debit), 0) END AS \"Balance\" FROM journal_line_items jli JOIN journal_entries je ON jli.journal_entry_id = je.id JOIN accounts a ON jli.account_id = a.id WHERE je.is_void = false GROUP BY a.account_type ORDER BY a.account_type",
          "refId": "A"
        }
      ],
      "title": "Account Balances by Type",
      "type": "barchart"
