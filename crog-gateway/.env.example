# CROG Gateway Configuration
# Copy this file to .env and fill in your actual values

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Feature Flags - The Strangler Pattern Controllers
ENABLE_AI_REPLIES=false
SHADOW_MODE=false
AI_INTENT_FILTER=

# RueBaRue SMS Provider (Legacy)
RUEBARUE_API_URL=https://api.ruebarue.com/v1
RUEBARUE_API_KEY=your_ruebarue_api_key_here
RUEBARUE_PHONE_NUMBER=+15551234567

# Streamline VRS (Legacy PMS)
STREAMLINE_API_URL=https://api.streamlinevrs.com/v2
STREAMLINE_API_KEY=your_streamline_api_key_here
STREAMLINE_PROPERTY_ID=your_property_id_here

# CROG AI System (New)
CROG_AI_URL=http://localhost:8000
CROG_AI_API_KEY=your_crog_ai_key_here

# Resiliency Settings
HTTP_TIMEOUT_SECONDS=30
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_SECONDS=2
