# .env.legal — credentials for legal corpus acquisition tools
# Copy to .env.legal and fill in your token. Never commit .env.legal.
#
# CourtListener (https://www.courtlistener.com/sign-in/)
# Free tier requires only email signup. Token used for API queries.
# Bulk downloads (courtlistener-bulk subcommand) do NOT require this token.
COURTLISTENER_API_TOKEN=CHANGE_ME_COURTLISTENER_API_TOKEN

# Optional: override NAS path for corpus storage
# LEGAL_CORPUS_ROOT=/mnt/fortress_nas/legal-corpus
