# CROG-AI Backend Environment — copy to .env and fill in real values
# .env is gitignored.

# Database (Postgres on Spark 2 today; Spark 3 after cutover)
CROG_AI_DB_HOST=127.0.0.1
CROG_AI_DB_PORT=5432
CROG_AI_DB_NAME=fortress_db
CROG_AI_DB_USER=crog_ai_app
CROG_AI_DB_PASSWORD=CHANGE_ME_CROG_AI_DB_PASSWORD

# Assembled URL used by Alembic env.py and SQLAlchemy engine
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# NAS paths (configurable so Spark 3 cutover is just an env edit)
NAS_MARKETCLUB_PATH=/mnt/vol1_source/Business/MarketClub
NAS_LOG_BASE=/mnt/fortress_nas/fortress_data/ai_brain/logs/crog_ai/phase1_nas_loader

# EOD market data vendor (Phase 2; deferred decision)
POLYGON_API_KEY=CHANGE_ME_POLYGON_API_KEY
ALPACA_API_KEY=CHANGE_ME_ALPACA_API_KEY
ALPACA_API_SECRET=CHANGE_ME_ALPACA_API_SECRET

# IMAP harvest (Phase 3; deferred until Legal pattern reviewed)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=CHANGE_ME_IMAP_PASSWORD
IMAP_MAILBOX=INBOX

# Logging
LOG_LEVEL=INFO
