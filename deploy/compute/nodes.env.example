#!/usr/bin/env bash
# Copy to deploy/compute/nodes.env and update values.

# NUC controller identity
NUC_HOSTNAME="fortress-nuc"
NUC_ROLE="controller"

# SSH user used by NUC to manage DGX nodes
DGX_SSH_USER="admin"
DGX_SSH_PORT="22"
SSH_CONNECT_TIMEOUT_SECONDS="8"
SSH_RETRIES="5"
SSH_RETRY_BACKOFF_SECONDS="2"

# Optional shared node inventory file (single source of truth).
# If set, SPARK_01_IP..SPARK_04_IP can be loaded from this file.
NODE_INVENTORY_FILE="/home/admin/Fortress-Prime/deploy/compute/node_inventory.env"

# Spark/DGX management LAN
SPARK_01_IP="192.168.0.100"
SPARK_02_IP="192.168.0.104"
SPARK_03_IP="192.168.0.105"
SPARK_04_IP="192.168.0.106"

# Comma-separated DGX node IPs or hostnames.
# Keep aligned with SPARK_01_IP..SPARK_04_IP unless a dedicated DGX fleet is used.
DGX_NODES="${SPARK_01_IP},${SPARK_02_IP},${SPARK_03_IP},${SPARK_04_IP}"

# Remote path where compute services run on DGX nodes
DGX_REMOTE_STACK_DIR="/opt/crog-fortress-ai"

# Optional registry login for pulling private images
CONTAINER_REGISTRY=""
CONTAINER_REGISTRY_USER=""
CONTAINER_REGISTRY_PASSWORD=""

# Compose file that should run on DGX nodes only
DGX_COMPOSE_FILE="docker-compose.compute.yml"

# Required for NVIDIA NIM startup/profile downloads.
# You can also keep this in project .env as NGC_API_KEY="..."
NGC_API_KEY=""

# Optional compose profile to run on DGX nodes.
# Supported: swarm, hydra, embeddings, inference(alias of swarm)
DGX_COMPOSE_PROFILE="swarm"

# Optional per-node profile override:
# Format "host_or_ip:profile,host_or_ip:profile"
# Example:
# DGX_NODE_PROFILES="${SPARK_01_IP}:swarm,${SPARK_02_IP}:hydra,${SPARK_03_IP}:embeddings"
DGX_NODE_PROFILES=""

# Post-deploy health probe settings (seconds)
DGX_HEALTHCHECK_TIMEOUT_SECONDS="600"
DGX_HEALTHCHECK_POLL_SECONDS="5"

