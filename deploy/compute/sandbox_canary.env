#!/usr/bin/env bash
# Copy to deploy/compute/sandbox_canary.env and update values.

# DGX host used for canary rollout.
DGX_CANARY_NODE="192.168.0.100"
DGX_SSH_USER="admin"
DGX_SSH_PORT="22"

# Remote app directory containing fortress-guest-platform backend.
REMOTE_APP_DIR="/home/admin/Fortress-Prime/fortress-guest-platform"

# Env override file written by rollout script (safe, reversible).
REMOTE_SANDBOX_ENV="/home/admin/Fortress-Prime/fortress-guest-platform/.env.sandbox"

# Runtime selector
SANDBOX_RUNTIME="firecracker"
SANDBOX_MEMORY_MB="512"
SANDBOX_VCPU_COUNT="1"

# Firecracker artifacts on the canary node
SANDBOX_FIRECRACKER_HELPER="/opt/firecracker/bin/fortress-firecracker-runner"
SANDBOX_FIRECRACKER_BIN="/opt/firecracker/bin/firecracker"
SANDBOX_JAILER_BIN="/opt/firecracker/bin/jailer"
SANDBOX_KERNEL_IMAGE="/opt/firecracker/images/kernel.bin"
SANDBOX_ROOTFS_IMAGE="/opt/firecracker/images/rootfs.ext4"
FORTRESS_FIRECRACKER_RUNNER_MODE="firecracker_microvm_scaffold"
FORTRESS_FIRECRACKER_FALLBACK_TO_HOST_ON_BOOT_FAIL="true"
FORTRESS_FIRECRACKER_EXECUTION_MODE="guest_exec"
FORTRESS_FIRECRACKER_GUEST_CID="3"
FORTRESS_GUEST_AGENT_PORT="5000"
FORTRESS_FIRECRACKER_GUEST_BOOT_WAIT_MS="900"
FORTRESS_FIRECRACKER_GUEST_INIT_DIRECT="true"

# Optional explicit restart command.
# If empty, script uses a safe default for backend.main:app on port 8100.
BACKEND_RESTART_CMD=""

# Health probe URL from the canary node itself.
HEALTHCHECK_URL="http://localhost:8100/health"
