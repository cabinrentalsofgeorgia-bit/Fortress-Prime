# 🛡️ FORTRESS PRIME - Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_HOST=localhost
DB_NAME=fortress_db
DB_USER=miner_bot
DB_PASS=CHANGE_ME_DB_PASS

# Google Gemini API Key (Required for Email Mining Rig)
GOOGLE_API_KEY=CHANGE_ME_GOOGLE_API_KEY

# ---------------------------------------------------------------------------
# Credentials required by src/ scripts — set via vault before running
# ---------------------------------------------------------------------------
ANALYST_WRITER_PASSWORD=CHANGE_ME_ANALYST_WRITER_PASSWORD

# Optional: Database connection overrides for Docker
# DB_HOST=postgres  # Use service name in Docker Compose
# DB_NAME=fortress_db
