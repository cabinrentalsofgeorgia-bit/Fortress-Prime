<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Secure Checkout — Cabin Rentals of Georgia</title>
<script src="https://js.stripe.com/v3/"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;background:#f3f4f6;color:#1f2937;min-height:100vh}
a{color:#059669;text-decoration:none}

/* ── Header ─────────────────────────────────────────────────── */
.checkout-header{background:#fff;border-bottom:1px solid #e5e7eb;padding:20px 32px;display:flex;align-items:center;gap:16px}
.checkout-header img{height:40px}
.checkout-header h1{font-size:18px;font-weight:600;color:#111827}
.checkout-header .secure-badge{margin-left:auto;font-size:13px;color:#059669;display:flex;align-items:center;gap:6px}
.checkout-header .secure-badge::before{content:'🔒'}

/* ── Main Grid ──────────────────────────────────────────────── */
.checkout-grid{max-width:1100px;margin:32px auto;display:grid;grid-template-columns:1fr 1fr;gap:32px;padding:0 24px}
@media(max-width:768px){.checkout-grid{grid-template-columns:1fr;gap:20px;margin:16px auto;padding:0 12px}}

/* ── Cards ──────────────────────────────────────────────────── */
.card{background:#fff;border-radius:12px;border:1px solid #e5e7eb;padding:28px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.card h2{font-size:16px;font-weight:700;margin-bottom:16px;color:#111827;text-transform:uppercase;letter-spacing:.04em}

/* ── Summary (Left) ─────────────────────────────────────────── */
.summary-property{margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #f3f4f6}
.summary-property:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.summary-property .prop-name{font-weight:600;font-size:15px;color:#111827}
.summary-property .prop-dates{font-size:13px;color:#6b7280;margin-top:2px}
.line-items{margin-top:12px}
.line-item{display:flex;justify-content:space-between;font-size:14px;padding:4px 0;color:#374151}
.line-item.total-row{border-top:1px solid #e5e7eb;margin-top:6px;padding-top:8px;font-weight:700;font-size:15px;color:#111827}

.grand-total-box{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:20px;text-align:center;margin-top:20px}
.grand-total-box .label{font-size:13px;color:#059669;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.grand-total-box .amount{font-size:36px;font-weight:800;color:#065f46;margin-top:4px}
.grand-total-box .currency{font-size:14px;color:#6b7280;margin-top:2px}

/* ── Payment (Right) ────────────────────────────────────────── */
.tab-bar{display:flex;border-bottom:2px solid #e5e7eb;margin-bottom:20px;gap:0}
.tab-btn{flex:1;padding:12px 8px;text-align:center;font-size:13px;font-weight:600;color:#6b7280;cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s}
.tab-btn.active{color:#059669;border-bottom-color:#059669}
.tab-btn:hover{color:#111827}
.tab-pane{display:none}
.tab-pane.active{display:block}

.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px}
.form-group input{width:100%;padding:12px 14px;border:1px solid #d1d5db;border-radius:8px;font-size:15px;color:#111827;background:#f9fafb;outline:none;transition:border-color .15s}
.form-group input:focus{border-color:#059669;background:#fff}

/* Stripe Elements container */
#stripe-card-element{padding:12px 14px;border:1px solid #d1d5db;border-radius:8px;background:#f9fafb;transition:border-color .15s}
#stripe-card-element.StripeElement--focus{border-color:#059669;background:#fff}
#stripe-card-element.StripeElement--invalid{border-color:#dc2626}
#card-errors{color:#dc2626;font-size:13px;margin-top:6px;min-height:20px}

.pay-btn{width:100%;padding:16px;border:none;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;transition:all .15s;margin-top:8px}
.pay-btn.primary{background:#059669;color:#fff}
.pay-btn.primary:hover{background:#047857}
.pay-btn.primary:disabled{background:#9ca3af;cursor:not-allowed}
.pay-btn.secondary{background:#f3f4f6;color:#374151;border:1px solid #d1d5db}
.pay-btn.secondary:hover{background:#e5e7eb}

.alt-instructions{background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;padding:20px;text-align:center;margin-bottom:16px}
.alt-instructions .icon{font-size:40px;margin-bottom:8px}
.alt-instructions h3{font-size:15px;font-weight:600;color:#111827;margin-bottom:8px}
.alt-instructions p{font-size:13px;color:#6b7280;line-height:1.6}
.alt-instructions .address{background:#fff;border:1px solid #d1d5db;border-radius:6px;padding:10px;font-family:'Courier New',monospace;font-size:12px;color:#111827;word-break:break-all;margin-top:10px}

/* ── Confirmation Overlay ───────────────────────────────────── */
.confirmation-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);z-index:9999;align-items:center;justify-content:center}
.confirmation-overlay.active{display:flex}
.confirmation-card{background:#fff;border-radius:16px;padding:48px;text-align:center;max-width:460px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.confirmation-card .icon{font-size:60px;margin-bottom:16px}
.confirmation-card h2{font-size:24px;font-weight:700;color:#065f46;margin-bottom:8px}
.confirmation-card p{font-size:15px;color:#6b7280;line-height:1.6}

/* ── Loading ────────────────────────────────────────────────── */
.loading-spinner{display:inline-block;width:20px;height:20px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle;margin-right:8px}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── Error / Empty ──────────────────────────────────────────── */
.error-page{max-width:500px;margin:80px auto;text-align:center;padding:24px}
.error-page .icon{font-size:48px;margin-bottom:12px}
.error-page h2{font-size:22px;color:#111827;margin-bottom:8px}
.error-page p{font-size:15px;color:#6b7280}
.loading-page{text-align:center;padding:80px 24px}
.loading-page .spinner{width:40px;height:40px;border:3px solid #e5e7eb;border-top-color:#059669;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px}

/* ── Stripe Trust Badge ─────────────────────────────────────── */
.stripe-badge{text-align:center;margin-top:14px;font-size:12px;color:#9ca3af}
.stripe-badge svg{width:52px;height:22px;vertical-align:middle;margin-right:4px}
</style>
</head>
<body>

<!-- Header -->
<div class="checkout-header">
  <img src="https://api.crog-ai.com/assets/crog-logo.png" alt="CROG" onerror="this.style.display='none'">
  <h1>Cabin Rentals of Georgia</h1>
  <span class="secure-badge">Secure Checkout</span>
</div>

<!-- Loading State -->
<div id="loadingView" class="loading-page">
  <div class="spinner"></div>
  <p style="color:#6b7280">Loading your quote&hellip;</p>
</div>

<!-- Error State -->
<div id="errorView" class="error-page" style="display:none">
  <div class="icon">⚠️</div>
  <h2 id="errorTitle">Quote Not Found</h2>
  <p id="errorMessage">We couldn't locate that quote. It may have expired or already been paid.</p>
</div>

<!-- Main Checkout Grid -->
<div id="checkoutView" class="checkout-grid" style="display:none">

  <!-- Left: Summary -->
  <div class="card">
    <h2>Booking Summary</h2>
    <div id="optionsList"></div>
    <div class="grand-total-box">
      <div class="label">Total Due</div>
      <div class="amount" id="grandTotalAmount">$0.00</div>
      <div class="currency">USD</div>
    </div>
  </div>

  <!-- Right: Payment -->
  <div class="card">
    <h2>Payment</h2>

    <div class="tab-bar">
      <button class="tab-btn active" data-tab="stripe">💳 Credit Card</button>
      <button class="tab-btn" data-tab="crypto">₿ Crypto</button>
      <button class="tab-btn" data-tab="zelle">⚡ Zelle</button>
    </div>

    <!-- Tab: Stripe (Elements) -->
    <div class="tab-pane active" id="tab-stripe">
      <div class="form-group">
        <label>Cardholder Name</label>
        <input type="text" id="cardName" placeholder="Jane Doe" autocomplete="cc-name">
      </div>
      <div class="form-group">
        <label>Card Details</label>
        <div id="stripe-card-element"></div>
        <div id="card-errors" role="alert"></div>
      </div>
      <button class="pay-btn primary" id="btnPayStripe" disabled>
        Pay <span id="stripeTotal">$0.00</span>
      </button>
      <div class="stripe-badge">
        <svg viewBox="0 0 60 25" xmlns="http://www.w3.org/2000/svg"><path d="M10.5 4.4c0-1.5 1.2-2.1 3.2-2.1 2.9 0 6.5 0.9 9.4 2.4V0.6C20.3 0.2 17.4 0 14.5 0 6.3 0 1 3.9 1 9.1c0 8.9 12.2 7.5 12.2 11.3 0 1.8-1.6 2.3-3.7 2.3-3.2 0-7.3-1.3-10.5-3.1v4.3c3.6 1.5 7.2 2.2 10.5 2.2 8.4 0 14.2-3.5 14.2-8.7C23.7 8.5 10.5 10.1 10.5 4.4z" fill="#9ca3af"/><path d="M60 12.2c0-5.6-2.7-10-7.9-10-5.2 0-8.3 4.4-8.3 10s3.1 9.8 8.6 9.8c2.5 0 4.4-0.6 5.8-1.4v-3.8c-1.4 0.7-3 1.2-5 1.2-2 0-3.7-0.7-3.9-3.1h9.9c0-0.3 0.8-2.7 0.8-2.7zM50 10.4c0-2.3 1.4-3.3 2.7-3.3 1.3 0 2.6 1 2.6 3.3H50z" fill="#9ca3af"/><path d="M37.7 2.2c-2 0-3.2 0.9-3.9 1.6l-0.3-1.3h-4.5V24l5.1-1.1v-5.2c0.7 0.5 1.8 1.3 3.5 1.3 3.5 0 6.7-2.8 6.7-9.1C44.3 4.8 41.2 2.2 37.7 2.2zm-1.2 14.4c-1.2 0-1.9-0.4-2.3-1v-7.7c0.5-0.6 1.2-1 2.3-1 1.8 0 3 2 3 4.8s-1.2 4.9-3 4.9z" fill="#9ca3af"/></svg>
        Powered by Stripe &middot; PCI Compliant
      </div>
    </div>

    <!-- Tab: Crypto -->
    <div class="tab-pane" id="tab-crypto">
      <div class="alt-instructions">
        <div class="icon">₿</div>
        <h3>Pay with USDC or BTC</h3>
        <p>Send the exact total amount to the wallet address below. Once the transaction is confirmed on-chain, your booking will be secured within 24 hours.</p>
        <div class="address">bc1q... (wallet address provided upon request)</div>
      </div>
      <button class="pay-btn secondary" id="btnPayCrypto">I Have Sent the Crypto</button>
    </div>

    <!-- Tab: Zelle -->
    <div class="tab-pane" id="tab-zelle">
      <div class="alt-instructions">
        <div class="icon">⚡</div>
        <h3>Pay with Zelle</h3>
        <p>Open your banking app, select <strong>Zelle</strong>, and send the exact total amount to:</p>
        <div class="address">payments@crog-ai.com</div>
        <p style="margin-top:10px">Include your <strong>confirmation code</strong> in the memo field.</p>
      </div>
      <button class="pay-btn secondary" id="btnPayZelle">I Have Sent the Zelle</button>
    </div>
  </div>
</div>

<!-- Confirmation Overlay -->
<div class="confirmation-overlay" id="confirmOverlay">
  <div class="confirmation-card">
    <div class="icon">🏔️</div>
    <h2 id="confirmTitle">Booking Confirmed!</h2>
    <p id="confirmMessage">Thank you for your reservation. You will receive a confirmation email shortly with check-in instructions.</p>
  </div>
</div>

<script>
(function(){
  var API_BASE = window.location.origin;
  var params = new URLSearchParams(window.location.search);
  var quoteId = params.get('quote');

  var loadingView = document.getElementById('loadingView');
  var errorView   = document.getElementById('errorView');
  var checkoutView = document.getElementById('checkoutView');
  var optionsList  = document.getElementById('optionsList');
  var grandTotalEl = document.getElementById('grandTotalAmount');
  var stripeTotalEl = document.getElementById('stripeTotal');
  var btnPayStripe = document.getElementById('btnPayStripe');
  var cardErrors   = document.getElementById('card-errors');

  var stripeInstance = null;
  var cardElement    = null;
  var clientSecret   = null;

  function showError(title, msg) {
    loadingView.style.display = 'none';
    checkoutView.style.display = 'none';
    errorView.style.display = 'block';
    document.getElementById('errorTitle').textContent = title;
    document.getElementById('errorMessage').textContent = msg;
  }

  function fmtMoney(v) {
    var n = parseFloat(v) || 0;
    return '$' + n.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
  }

  function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

  if (!quoteId) {
    showError('Missing Quote', 'No quote ID was provided in the URL. Please use the link from your email.');
    return;
  }

  // ── 1. Fetch quote summary ─────────────────────────────────
  fetch(API_BASE + '/api/vrs/checkout/' + quoteId)
    .then(function(r) {
      if (!r.ok) return r.json().then(function(j) { throw new Error(j.detail || 'Failed to load quote'); });
      return r.json();
    })
    .then(function(data) {
      loadingView.style.display = 'none';
      checkoutView.style.display = 'grid';

      var html = '';
      (data.options || []).forEach(function(opt) {
        html += '<div class="summary-property">';
        html += '<div class="prop-name">' + esc(opt.property_name) + '</div>';
        html += '<div class="prop-dates">' + esc(opt.check_in_date) + ' &rarr; ' + esc(opt.check_out_date) + ' &middot; ' + opt.nights + ' night' + (opt.nights !== 1 ? 's' : '') + '</div>';
        html += '<div class="line-items">';
        html += '<div class="line-item"><span>Base Rent</span><span>' + fmtMoney(opt.base_rent) + '</span></div>';
        html += '<div class="line-item"><span>Taxes</span><span>' + fmtMoney(opt.taxes) + '</span></div>';
        html += '<div class="line-item"><span>Fees</span><span>' + fmtMoney(opt.fees) + '</span></div>';
        html += '<div class="line-item total-row"><span>Subtotal</span><span>' + fmtMoney(opt.total_price) + '</span></div>';
        html += '</div></div>';
      });
      optionsList.innerHTML = html;

      var gt = fmtMoney(data.grand_total);
      grandTotalEl.textContent = gt;
      stripeTotalEl.textContent = gt;

      initStripeElements();
    })
    .catch(function(err) {
      showError('Error', err.message);
    });

  // ── 2. Initialize Stripe Elements ──────────────────────────
  function initStripeElements() {
    fetch(API_BASE + '/api/vrs/checkout/' + quoteId + '/create-intent', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
    })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(j) { throw new Error(j.detail || 'Failed to create payment intent'); });
      return r.json();
    })
    .then(function(data) {
      clientSecret = data.client_secret;
      var pk = data.publishable_key;

      if (!pk || pk.indexOf('pk_') !== 0) {
        cardErrors.textContent = 'Stripe is not configured. Please contact support.';
        return;
      }

      stripeInstance = Stripe(pk);
      var elements = stripeInstance.elements();
      cardElement = elements.create('card', {
        style: {
          base: {
            fontSize: '16px',
            color: '#111827',
            fontFamily: '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif',
            '::placeholder': {color: '#9ca3af'},
          },
          invalid: {color: '#dc2626'},
        }
      });
      cardElement.mount('#stripe-card-element');

      cardElement.on('change', function(event) {
        if (event.error) {
          cardErrors.textContent = event.error.message;
          btnPayStripe.disabled = true;
        } else {
          cardErrors.textContent = '';
          btnPayStripe.disabled = !event.complete;
        }
      });
    })
    .catch(function(err) {
      cardErrors.textContent = 'Could not initialize payment: ' + err.message;
    });
  }

  // ── 3. Tab switching ───────────────────────────────────────
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
      document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });
      this.classList.add('active');
      document.getElementById('tab-' + this.dataset.tab).classList.add('active');
    });
  });

  // ── 4. Stripe Card Payment ─────────────────────────────────
  btnPayStripe.addEventListener('click', function() {
    if (!stripeInstance || !cardElement || !clientSecret) {
      cardErrors.textContent = 'Payment system not ready. Please wait or refresh.';
      return;
    }

    var origHtml = btnPayStripe.innerHTML;
    btnPayStripe.disabled = true;
    btnPayStripe.innerHTML = '<span class="loading-spinner"></span> Processing&hellip;';
    cardErrors.textContent = '';

    var cardholderName = document.getElementById('cardName').value.trim();

    stripeInstance.confirmCardPayment(clientSecret, {
      payment_method: {
        card: cardElement,
        billing_details: {name: cardholderName || undefined},
      }
    }).then(function(result) {
      if (result.error) {
        cardErrors.textContent = result.error.message;
        btnPayStripe.disabled = false;
        btnPayStripe.innerHTML = origHtml;
      } else if (result.paymentIntent && result.paymentIntent.status === 'succeeded') {
        fetch(API_BASE + '/api/vrs/checkout/' + quoteId + '/complete', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({
            payment_method: 'stripe',
            payment_metadata: {payment_intent_id: result.paymentIntent.id}
          })
        }).catch(function() {});
        document.getElementById('confirmTitle').textContent = 'Booking Confirmed!';
        document.getElementById('confirmMessage').textContent =
          'Payment successful! You will receive a confirmation email with your receipt and rental agreement shortly.';
        document.getElementById('confirmOverlay').classList.add('active');
      } else {
        cardErrors.textContent = 'Unexpected payment status: ' + (result.paymentIntent ? result.paymentIntent.status : 'unknown');
        btnPayStripe.disabled = false;
        btnPayStripe.innerHTML = origHtml;
      }
    });
  });

  // ── 5. Crypto / Zelle (manual rails — unchanged) ──────────
  function submitManualPayment(method, btn) {
    var origHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="loading-spinner"></span> Processing&hellip;';

    fetch(API_BASE + '/api/vrs/checkout/' + quoteId + '/complete', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({payment_method: method})
    })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(j) { throw new Error(j.detail || 'Payment failed'); });
      return r.json();
    })
    .then(function(data) {
      document.getElementById('confirmTitle').textContent = 'Payment Submitted';
      document.getElementById('confirmMessage').textContent = data.message || 'Thank you!';
      document.getElementById('confirmOverlay').classList.add('active');
    })
    .catch(function(err) {
      btn.disabled = false;
      btn.innerHTML = origHtml;
      alert('Payment error: ' + err.message);
    });
  }

  document.getElementById('btnPayCrypto').addEventListener('click', function() { submitManualPayment('crypto', this); });
  document.getElementById('btnPayZelle').addEventListener('click', function() { submitManualPayment('zelle', this); });
})();
</script>
</body>
</html>
