{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortress-legal/remediation-registry.schema.json",
  "title": "Fortress Legal Remediation Registry",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "sourceRefs", "standingLabels", "governanceBoundaries", "evidenceRefs", "validationStatus", "rollbackRefs", "noSecrets", "noConfidentialText", "humanReviewRequired", "unresolvedSourceIssues", "noAutoResolution"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "generatedAt": { "type": "string" },
    "sourceRefs": { "type": "array", "items": { "type": "string" } },
    "standingLabels": { "type": "object" },
    "governanceBoundaries": { "type": "array", "items": { "type": "string" } },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "validationStatus": { "type": "object" },
    "rollbackRefs": { "type": "array", "items": { "type": "string" } },
    "noSecrets": { "const": true },
    "noConfidentialText": { "const": true },
    "humanReviewRequired": { "const": true },
    "unresolvedSourceIssues": { "type": "integer", "minimum": 0 },
    "noAutoResolution": { "const": true }
  },
  "additionalProperties": true
}
