{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fortress.local/contracts/revenue-chain-of-custody.schema.json",
  "title": "Revenue Quote Chain Of Custody V1",
  "type": "object",
  "required": ["quote_id", "raw_total", "tax_total", "timestamp", "hmac_sig"],
  "properties": {
    "quote_id": {
      "type": "string",
      "minLength": 1
    },
    "raw_total": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{2}$"
    },
    "tax_total": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{2}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "hmac_sig": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false
}
