# Fortress Prime DGX runtime overlay
# Copy to: /home/admin/Fortress-Prime/fortress-guest-platform/.env.dgx
# Loaded by `fortress-backend.service` after the base `.env`.

# ---------------------------------------------------------------------------
# Sovereign telemetry topology observed on this DGX host
# ---------------------------------------------------------------------------
# Active uplink:
# - enP7s7   ifindex=2   addresses=10.10.10.2/24,192.168.0.100/24
#
# Additional physical NICs detected:
# - enp1s0f0np0   ifindex=3   state=UP   RoCE lane 1 backplane 10.101.1.x/30
# - enp1s0f1np1   ifindex=4   state=DOWN
# - enP2p1s0f0np0 ifindex=5   state=UP   RoCE lane 2 backplane 10.101.2.x/30
# - enP2p1s0f1np1 ifindex=6   state=DOWN
#
# These host ifindex values are documented here for operator review. The actual
# `SYSTEM_HEALTH_MIKROTIK_SNMP_IF_INDICES` value must match the MikroTik IF-MIB
# numbering for the DGX-facing switch ports you intend to poll.

# ---------------------------------------------------------------------------
# PostgreSQL 16 — loopback or dual-lane 200G RoCE backplane
# ---------------------------------------------------------------------------
# Primary lane (Captain colocated with DB on spark-node-2): use 10.101.1.2.
# Use 127.0.0.1 only for dev or when you explicitly want loopback.
POSTGRES_API_URI=postgresql://USER:PASSWORD@HOST:5432/DBNAME
POSTGRES_ADMIN_URI=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ---------------------------------------------------------------------------
# Qdrant — client URL + HTTP readiness (system health)
# ---------------------------------------------------------------------------
QDRANT_URL=http://10.101.1.2:6333
QDRANT_HTTP_URL=http://10.101.1.2:6333

# ---------------------------------------------------------------------------
# Event bus — Redpanda (external listener on backplane; compose: tools/docker/docker-compose.yml)
# ---------------------------------------------------------------------------
KAFKA_BROKER_URL=10.101.1.2:19092

# Channex (or compatible aggregator) — HMAC SHA-256 of raw POST body, header x-channex-signature (hex digest)
# CHANNEX_WEBHOOK_SECRET=CHANGE_ME_CHANNEX_WEBHOOK_SECRET

# Channex egress — python -m backend.workers.channex_egress (availability push; set path to match vendor API)
# CHANNEX_API_BASE_URL=https://api.channex.io
# CHANNEX_API_KEY=CHANGE_ME_CHANNEX_API_KEY
# CHANNEX_AVAILABILITY_PATH=/api/v1/channel/availability
# CHANNEX_EGRESS_VERIFY_SSL=true

# Optional: Nemoclaw event consumer (python -m backend.workers.event_consumer)
# EVENT_CONSUMER_TOPICS=trust.revenue.staged,reservation.confirmed
# EVENT_CONSUMER_GROUP_ID=fortress-nemoclaw-consumers
# EVENT_CONSUMER_AUTO_OFFSET_RESET=latest
# NEMOCLAW_ORCHESTRATOR_URL=http://192.168.0.100:8000
# NEMOCLAW_ORCHESTRATOR_API_KEY=CHANGE_ME_NEMOCLAW_ORCHESTRATOR_API_KEY

# ---------------------------------------------------------------------------
# Local inference + embeddings (Phase 1 RAG path)
# ---------------------------------------------------------------------------
# Ollama exposes OpenAI-compatible POST {EMBED_BASE_URL}/v1/embeddings
EMBED_BASE_URL=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text
# LiteLLM (or compatible) chat proxy — scripts/verify_rag_inference.py optional step
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
# LITELLM_MASTER_KEY=CHANGE_ME_LITELLM_MASTER_KEY

# ---------------------------------------------------------------------------
# Streamline VRS (Phase 2 ingestion — scripts/run_streamline_sync.py)
# ---------------------------------------------------------------------------
# STREAMLINE_API_URL=https://web.streamlinevrs.com/api/json
# STREAMLINE_API_KEY=CHANGE_ME_STREAMLINE_API_KEY
# STREAMLINE_API_SECRET=CHANGE_ME_STREAMLINE_API_SECRET

# ---------------------------------------------------------------------------
# System Health telemetry (FastAPI -> Command Center)
# ---------------------------------------------------------------------------
# Preferred mode: SNMPv3 against the MikroTik / switch control plane.
SYSTEM_HEALTH_MIKROTIK_SNMP_HOST=192.168.88.1
SYSTEM_HEALTH_MIKROTIK_SNMP_PORT=161
SYSTEM_HEALTH_MIKROTIK_SNMP_VERSION=v3
SYSTEM_HEALTH_MIKROTIK_SNMP_IF_INDICES=2,3,5
SYSTEM_HEALTH_MIKROTIK_SNMP_V3_USERNAME=fortress_telemetry
SYSTEM_HEALTH_MIKROTIK_SNMP_V3_AUTH_PROTOCOL=SHA
SYSTEM_HEALTH_MIKROTIK_SNMP_V3_AUTH_KEY=CHANGE_ME_SYSTEM_HEALTH_MIKROTIK_SNMP_V3_AUTH_KEY
SYSTEM_HEALTH_MIKROTIK_SNMP_V3_PRIV_PROTOCOL=AES128
SYSTEM_HEALTH_MIKROTIK_SNMP_V3_PRIV_KEY=CHANGE_ME_SYSTEM_HEALTH_MIKROTIK_SNMP_V3_PRIV_KEY

# v2c fallback: only use on a strictly isolated management LAN / Synology target.
# SYSTEM_HEALTH_MIKROTIK_SNMP_VERSION=v2c
# SYSTEM_HEALTH_MIKROTIK_SNMP_COMMUNITY=REPLACE_WITH_ISOLATED_V2C_COMMUNITY

# ---------------------------------------------------------------------------
# Sovereign NAS mounts observed on this DGX host
# ---------------------------------------------------------------------------
# Live NFS mounts detected:
# - /mnt/fortress_nas  -> 192.168.0.113:/volume1/ai-data-new
# - /mnt/ai_bulk       -> 192.168.0.113:/volume1/ai_bulk
#
# Include only the mounts you want exposed to the Command Center.
SYSTEM_HEALTH_SYNOLOGY_MOUNT_PATHS=/mnt/fortress_nas,/mnt/ai_bulk
