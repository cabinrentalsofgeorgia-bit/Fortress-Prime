# ============================================================================
# Fortress Guest Platform - Environment Configuration
# ============================================================================

# Application
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true
API_PORT=8100
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://miner_bot:your_password@localhost:5432/fortress_guest
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_STATUS_CALLBACK_URL=https://crog-ai.com/webhooks/sms/status

# OpenAI
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7

# Claude (Alternative)
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Qdrant (Vector Database)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=fgp_knowledge

# PMS Integration (Streamline VRS)
STREAMLINE_API_URL=https://api.streamlinevrs.com
STREAMLINE_API_KEY=your_streamline_key
STREAMLINE_PROPERTY_ID=your_property_id
STREAMLINE_SYNC_INTERVAL=300  # seconds

# Feature Flags
ENABLE_AI_RESPONSES=true
ENABLE_AUTO_REPLIES=false  # Requires human review if false
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_PREDICTIVE_ANALYTICS=false
ENABLE_MULTI_LANGUAGE=false

# Messaging
MAX_MESSAGE_LENGTH=1600
MESSAGE_RATE_LIMIT=100  # messages per hour per guest
AI_CONFIDENCE_THRESHOLD=0.75  # 0.0-1.0

# Scheduler
SCHEDULER_TIMEZONE=America/New_York
MESSAGE_SEND_START_HOUR=8  # 8am
MESSAGE_SEND_END_HOUR=21   # 9pm

# Notifications
STAFF_NOTIFICATION_PHONE=+17065255482
STAFF_NOTIFICATION_EMAIL=lissa@cabin-rentals-of-georgia.com
URGENT_ISSUE_KEYWORDS=emergency,urgent,broken,not working,help

# Security
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:3000,https://crog-ai.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/fortress-guest-platform/app.log
