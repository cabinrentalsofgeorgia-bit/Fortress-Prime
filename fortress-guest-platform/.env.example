# Fortress Prime baseline environment
# Copy to `fortress-guest-platform/.env` for local development.
# Use `fortress-guest-platform/.env.dgx.example` for DGX host-specific overrides.

# ---------------------------------------------------------------------------
# Required backend startup variables
# ---------------------------------------------------------------------------
POSTGRES_API_URI=postgresql://fortress_api:REPLACE_ME@127.0.0.1:5432/fortress_prod
POSTGRES_ADMIN_URI=postgresql://fortress_admin:REPLACE_ME@127.0.0.1:5432/fortress_prod

# Auth: provide RS256 keys in PEM or base64-encoded PEM form.
JWT_RSA_PRIVATE_KEY=
JWT_RSA_PUBLIC_KEY=
JWT_KEY_ID=fgp-rs256-v1

# Worker-to-API auth and shared application secret compatibility.
SWARM_API_KEY=REPLACE_ME
INTERNAL_API_TOKEN=
JWT_SECRET_KEY=compat-jwt-secret-not-used-for-auth

# ---------------------------------------------------------------------------
# Frontend/backend local routing
# ---------------------------------------------------------------------------
FGP_BACKEND_URL=http://127.0.0.1:8100
NEXT_PUBLIC_APP_URL=http://localhost:3001
INTERNAL_API_BASE_URL=http://127.0.0.1:8100

# ---------------------------------------------------------------------------
# Core local services
# ---------------------------------------------------------------------------
QDRANT_URL=http://127.0.0.1:6333
QDRANT_HTTP_URL=http://127.0.0.1:6333
KAFKA_BROKER_URL=127.0.0.1:19092
REDIS_URL=redis://127.0.0.1:6379/0
ARQ_REDIS_URL=redis://127.0.0.1:6379/1

# ---------------------------------------------------------------------------
# Optional payment + OTA integrations
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
CHANNEX_WEBHOOK_SECRET=
CHANNEX_API_BASE_URL=
CHANNEX_API_KEY=

# ---------------------------------------------------------------------------
# Optional sovereign AI endpoints
# ---------------------------------------------------------------------------
DGX_INFERENCE_URL=
DGX_INFERENCE_MODEL=
DGX_INFERENCE_API_KEY=
NEMOCLAW_ORCHESTRATOR_URL=http://127.0.0.1:8000
NEMOCLAW_ORCHESTRATOR_API_KEY=
EMBED_BASE_URL=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text


# ---------------------------------------------------------------------------
# Owner Statement System (Phase F) — two operational toggles
# ---------------------------------------------------------------------------
# CROG_STATEMENTS_PARALLEL_MODE: When true (default), the 15th-of-month send
# job generates statements for internal comparison ONLY — no emails go to
# owners. Set to false ONLY after Phase G validation completes and the product
# owner has explicitly approved the production cutover.
CROG_STATEMENTS_PARALLEL_MODE=true

# OWNER_STATEMENT_ALERT_EMAIL: Required for monitoring. Set to the email
# address that should receive a run-summary after every cron job fires (both
# the 12th generation job and the 15th send job). Leave empty to disable alert
# emails (useful in development environments).
OWNER_STATEMENT_ALERT_EMAIL=

# ---------------------------------------------------------------------------
# Test database isolation (Phase G.1.7)
# ---------------------------------------------------------------------------
# Required for tests to run against a dedicated test database instead of
# polluting fortress_shadow (the production runtime DB).
# Run backend/scripts/setup_test_db.sh once to create the test DB and bring
# it to the current alembic head.
# Without this variable, conftest.py warns and tests fall back to fortress_shadow.
TEST_DATABASE_URL=postgresql://fortress_api:fortress@127.0.0.1:5432/fortress_shadow_test
