# Staging public origin for the Next.js storefront.
NEXT_PUBLIC_SITE_URL=https://staging.cabin-rentals-of-georgia.com

# Kept alongside NEXT_PUBLIC_SITE_URL because parts of the app still read this alias.
NEXT_PUBLIC_APP_URL=https://staging.cabin-rentals-of-georgia.com

# Public API origin for browser-side requests on staging.
NEXT_PUBLIC_API_URL=https://staging-api.crog-ai.com

# Optional explicit websocket origin. When omitted, the app derives it from NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_WS_URL=wss://staging-api.crog-ai.com/ws

# Optional: full URL for 1 Hz system-health telemetry (JWT appended as ?token=). When omitted,
# derived from NEXT_PUBLIC_WS_URL (…/ws → …/api/telemetry/ws/system-health).
# NEXT_PUBLIC_SYSTEM_HEALTH_WS_URL=wss://staging-api.crog-ai.com/api/telemetry/ws/system-health

# Server-side FastAPI origin used by RSC fetches, API routes, and metadata generation.
# Point this at the DGX Cloudflare Tunnel for staging, not localhost.
FGP_BACKEND_URL=https://staging-api.crog-ai.com

# --- Command Center (crog-ai.com) deploy ---
# Prefer explicit mode so / and /login always serve staff UI even if Host detection fails in edge cases.
# APP_MODE=command_center
# NEXT_PUBLIC_SITE_TYPE=sovereign_glass
# Public origin of the staff app (metadataBase, robots host).
# NEXT_PUBLIC_COMMAND_CENTER_URL=https://crog-ai.com
# Optional: comma-separated extra staff hostnames (Cloudflare tunnel hostname, internal DNS).
# Must match next build env so Server Actions allowlist includes them (rebuild after change).
# NEXT_PUBLIC_STAFF_HOSTS=command.crog-ai.com,staff.example.internal

# Next.js edge revalidation secret used by the backend deploy consumer.
EDGE_REVALIDATION_SECRET=replace-with-staging-edge-secret
